PORT=5000
# Admin auth for write operations
ADMIN_PASSWORD=
NODE_ENV=production
JWT_SECRET=your_jwt_secret_key_here

# Auto Rotation - Enable automatic rotation advancement
# Set to 'true' to automatically create upcoming rotations for interns
# Set to 'false' to disable auto-rotation (manual management only)
AUTO_ROTATION=true

# Database Configuration
# MongoDB Atlas connection string (must include database name, e.g. spinDB)
# Example:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/spinDB?retryWrites=true&w=majority
MONGO_URI=

CORS_ORIGIN=https://spin-interns.vercel.app
CLOUD_BACKUP_PROVIDER=googledrive
AUTO_RESTORE_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_TIME=02:00
BACKUP_RETENTION_COUNT=10

# OneDrive Configuration (if using OneDrive)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=common

# Google Drive Configuration (if using Google Drive)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
